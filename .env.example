APP_NAME=conversational-ai-backend
ENVIRONMENT=dev
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./var/app.db
LLM_PROVIDER=openrouter
TASK_LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Fireside Conversation AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TASK_OPENAI_MODEL=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=2048
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEFAULT_MODEL=llama3.1
REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
CONTEXT_TOKEN_BUDGET=6000
SUMMARY_TRIGGER_TOKENS=4500
WINDOW_TURN_COUNT=12
CUSTOM_PERSONA_MAX_CHARS=800
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=
CHROMA_PERSIST_DIR=./var/chroma
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_TOKEN_BUDGET=1500
RAG_MAX_UPLOAD_BYTES=10485760
MCP_USER_ID=
MCP_TASK_ID=
# Task agent MCP transport: streamable_http (mounted /mcp) or stdio (python -m app.mcp).
MCP_TRANSPORT=streamable_http
MCP_STREAMABLE_URL=http://127.0.0.1:8000/mcp/
# Optional shared bearer for TaskService → /mcp (user JWTs are also accepted).
MCP_HTTP_AUTH_TOKEN=
# Optional JSON list, e.g. ["python","-m","app.mcp"]. Default: current interpreter -m app.mcp
MCP_SERVER_COMMAND=
MCP_SERVER_CWD=
