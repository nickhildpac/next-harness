APP_NAME=conversational-ai-backend
ENVIRONMENT=dev
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./var/app.db
OLLAMA_BASE_URL=http://localhost:11434
LLM_PROVIDER=ollama
DEFAULT_MODEL=llama3.1
REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
CONTEXT_TOKEN_BUDGET=6000
SUMMARY_TRIGGER_TOKENS=4500
WINDOW_TURN_COUNT=12
CUSTOM_PERSONA_MAX_CHARS=800

